# Abandoned checkout WhatsApp recovery. The reminder message, the wait time and
# the on/off switch are edited from the dashboard (Cart Recovery tab) and stored
# in the database, so no template config lives here. These two knobs are optional
# tuning: how often Shopify is polled, and how far back to look for carts.
ABANDONED_CHECKOUT_POLL_MINUTES=5
ABANDONED_CHECKOUT_LOOKBACK_HOURS=24
# Name used in the reminder when Shopify has no first name for the customer.
WHATSAPP_ABANDONED_NAME_FALLBACK=cliente
DATABASE_URL=
SHOPIFY_STORE=
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_CLIENT_ID=
